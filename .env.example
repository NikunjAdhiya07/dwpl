# MongoDB Connection
# Copy this file to .env.local and fill in your actual credentials
# NEVER commit .env.local to git!

# For local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/dwpl

# For MongoDB Atlas (recommended — SRV is auto-resolved to a standard URI):
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/dwpl?retryWrites=true&w=majority

# Optional: bypass SRV DNS entirely if your network blocks SRV lookups.
# Get this from Atlas → Connect → Drivers → "Standard connection string"
# MONGODB_URI_DIRECT=mongodb://username:password@host1:27017,host2:27017,host3:27017/dwpl?ssl=true&replicaSet=...&authSource=admin

# Example:
# MONGODB_URI=mongodb+srv://myuser:mypassword@cluster0.abcde.mongodb.net/dwpl?retryWrites=true&w=majority
